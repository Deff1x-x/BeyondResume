APP_ENV=local
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Docker Compose service hostname. For local uvicorn on the host use 127.0.0.1 instead of postgres.
DATABASE_URL=postgresql+psycopg://ebh:ebh@postgres:5432/ebh

# Required for login/register token issuance. Copy to .env and set a long random value.
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_ACCESS_TTL_MINUTES=15

UPLOAD_DIR=/app/data/uploads
MAX_RESUME_MB=8

LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=gpt-5-mini
LLM_TIMEOUT_SECONDS=20

GITHUB_CLONE_TIMEOUT_SECONDS=30
GITHUB_MAX_REPO_MB=15
GITHUB_MAX_FILES=60
GITHUB_MAX_FILE_KB=40
GITHUB_MAX_CONTEXT_KB=100

# Select the deterministic fixture provider or the public GitHub API provider.
GITHUB_PROVIDER=live
# Optional for public repositories; supplied tokens are sent as Bearer credentials.
GITHUB_TOKEN=
